# API Keys para Content Automation

# Groq API (gratuito con límites)
# Obtén tu API key en: https://console.groq.com
GROQ_API_KEY=tu_groq_api_key_aqui

# Google Gemini API (tiene tier gratuito)
# Obtén tu API key en: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_google_api_key_aqui

# Tavily API (1000 búsquedas/mes gratis)
# Obtén tu API key en: https://tavily.com
TAVILY_API_KEY=tu_tavily_api_key_aqui
